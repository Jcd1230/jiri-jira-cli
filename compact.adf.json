ec-040ca953fc57","panelType":"info"},"content":[{"attrs":{"localId":"2c1f42dd-9104-4992-9db3-ef894dbf89c4"},"content":[{"text":"Currently, most developers on the team are using Intellij IDEA.","type":"text"}],"type":"paragraph"}],"type":"panel"},{"attrs":{"localId":"73ac8340-ec9d-4e18-b252-17955d17d18b"},"type":"rule"},{"attrs":{"localId":"def0e3c4-af5c-4595-a1b2-db11b84df364","panelColor":"#FFEBE6","panelIcon":":dumpling:","panelIconId":"1f95f","panelIconText":"🥟","panelType":"custom"},"content":[{"attrs":{"level":2,"localId":"1cc883dc-c024-40dc-89ad-f5be439fa7ee"},"content":[{"text":"Mise-En-Place (Pronounced \"MEEZ ahn plahs\") ","type":"text"}],"type":"heading"}],"type":"panel"},{"attrs":{"localId":"3717998f-61c6-4a0a-8ad3-d2e2a1355f1d"},"content":[{"text":"Mise-en-place means “set up everything you need before you start,” so execution is smooth, fast, and low-risk.","type":"text"}],"type":"paragraph"},{"attrs":{"localId":"27f9dc7c-f82f-4f9f-bc4d-c3439a2d6297"},"content":[{"text":"Website: ","type":"text"},{"attrs":{"localId":"2bbd1284-fb59-4a7a-acdc-e019066549af","url":"https://mise.jdx.dev/"},"type":"inlineCard"},{"text":" ","type":"text"}],"type":"paragraph"},{"attrs":{"localId":"0787e47f71b2"},"type":"paragraph"},{"attrs":{"localId":"e54cca0f-6242-4573-b99b-1d943d0b67b9"},"content":[{"text":"To install Mise please follow the instructions provided by our internal Infrastructure team: ","type":"text"},{"attrs":{"localId":"b9d68679-6983-43bd-b381-d1bd043ede1a","url":"https://kunzleigh.atlassian.net/wiki/x/CIBTPAE"},"type":"inlineCard"},{"text":" ","type":"text"}],"type":"paragraph"},{"attrs":{"localId":"f41704e1-40d9-421f-bf64-21517e87fb84","panelColor":"#FFEBE6","panelIcon":":whale:","panelIconId":"1f433","panelIconText":"🐳","panelType":"custom"},"content":[{"attrs":{"level":2,"localId":"89ee53e3-027d-4958-9a1b-ca2294ac5e1d"},"content":[{"text":"Docker/WSL","type":"text"}],"type":"heading"}],"type":"panel"},{"attrs":{"localId":"9a7510e7-e71d-46b8-8ca4-05136a5f